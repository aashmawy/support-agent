# Required for running the agent (and for live evals). Leave empty to use mocks in tests.
# Set your key here or in .env (never commit .env with a real key)
OPENAI_API_KEY=


# Path to SQLite support database. Created by `make init-db` or `scripts/init_db.py`.
SUPPORT_DB_PATH=./data/support.db

# Path to support documentation corpus (markdown files).
SUPPORT_DOCS_PATH=./data/docs
